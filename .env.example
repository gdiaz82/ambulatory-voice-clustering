# Copy to `.env` and adjust. Paths override the defaults in config/default.yaml.
# All paths may be absolute or relative to the project root.

# Root of the raw MGH .mat dataset (HDF5 / MATLAB v7.3), one folder per subject.
AVC_RAW_DIR=data/raw

# Where intermediate (master parquet) and processed (subsequences, clustered) outputs go.
AVC_INTERIM_DIR=data/interim
AVC_PROCESSED_DIR=data/processed

# Force a compute backend: "cpu", "gpu", or "auto" (default: auto-detect).
AVC_BACKEND=auto

# Global random seed.
AVC_SEED=42
